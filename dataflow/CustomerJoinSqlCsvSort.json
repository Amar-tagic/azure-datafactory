{
	"name": "CustomerJoinSqlCsvSort",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "sales_product_read",
						"type": "DatasetReference"
					},
					"name": "productFromcsv"
				},
				{
					"dataset": {
						"referenceName": "csv_read_sales_input_customer",
						"type": "DatasetReference"
					},
					"name": "CustomerAddressCsv"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "Parquetwritesales",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "join1"
				},
				{
					"name": "filter1"
				},
				{
					"name": "sort1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          productCode as string,",
				"          productName as string,",
				"          productLine as string,",
				"          productScale as string,",
				"          productVendor as string,",
				"          productDescription as string,",
				"          quantityInStock as string,",
				"          buyPrice as string,",
				"          MSRP as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> productFromcsv",
				"source(output(",
				"          customerNumber as long,",
				"          customerName as string,",
				"          contactLastName as string,",
				"          contactFirstName as string,",
				"          phone as string,",
				"          addressLine1 as string,",
				"          addressLine2 as string,",
				"          city as string,",
				"          state as string,",
				"          postalCode as string,",
				"          country as string,",
				"          salesRepEmployeeNumber as string,",
				"          creditLimit as float",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     limit: 100,",
				"     ignoreNoFilesFound: false,",
				"     dateFormats: ['yyyy/MM/dd'],",
				"     timestampFormats: ['yyyy-MM-dd\\'T\\'HH:mm:ss'],",
				"     preferredIntegralType: 'long',",
				"     preferredFractionalType: 'float') ~> CustomerAddressCsv",
				"productFromcsv join(customerNumber == ERROR_FUNCTION(''),",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"join1 filter(ERROR_FUNCTION('')) ~> filter1",
				"filter1 sort(asc(ERROR_FUNCTION(''), true)) ~> sort1",
				"sort1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'parquet',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}