{
	"name": "CustomerJoinSqlCsvSort",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "AzureSalesOrder",
						"type": "DatasetReference"
					},
					"name": "CustomerFromSql"
				},
				{
					"dataset": {
						"referenceName": "csvread",
						"type": "DatasetReference"
					},
					"name": "CustomerAddressCsv"
				}
			],
			"sinks": [
				{
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "join1"
				},
				{
					"name": "filter1"
				},
				{
					"name": "sort1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          orderNumber as integer,",
				"          orderDate as date,",
				"          requiredDate as date,",
				"          shippedDate as date,",
				"          status as string,",
				"          comments as string,",
				"          customerNumber as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> CustomerFromSql",
				"source(output(",
				"          {\"customer_key\";\"customer_id\";\"first_name\";\"last_name\";\"gender\";\"email\";\"phone\";\"country\";\"state\";\"city\";\"join_date\"} as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     limit: 100,",
				"     ignoreNoFilesFound: false,",
				"     dateFormats: ['yyyy/MM/dd'],",
				"     timestampFormats: ['yyyy-MM-dd\\'T\\'HH:mm:ss'],",
				"     preferredIntegralType: 'long',",
				"     preferredFractionalType: 'float') ~> CustomerAddressCsv",
				"CustomerFromSql join(customerNumber == ERROR_FUNCTION(''),",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"join1 filter(ERROR_FUNCTION('')) ~> filter1",
				"filter1 sort(asc(ERROR_FUNCTION(''), true)) ~> sort1",
				"sort1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}